# Copy to .env and edit. bootstrap.sh sources this if present.

# Required — Git repo hosting rhoai-2254-install/
REPO_URL=https://github.com/yourorg/rhoai-migrations.git

# Optional — Git revision Argo CD tracks (default: main)
TARGET_REVISION=main

# Optional — which overlay under gitops/overlays/ to deploy (default: all)
# Available overlays:
#   all      — full pre-migration state (every component + every sample)
#   minimal  — operators + DSC only, no samples
OVERLAY=all
